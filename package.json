{
  "name": "paltocraft",
  "version": "1.1.0",
  "description": "PaltoCraft - Minecraft Launcher with Microsoft Auth",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "node build.js",
    "build:quick": "electron-packager .build PaltoCraft --platform=win32 --arch=x64 --out=dist --overwrite --app-version=1.0.0 --icon=assets/icon.ico --asar.unpackDir=node_modules --prune --ignore=dist"
  },
  "build": {
    "appId": "com.paltocraft.launcher",
    "productName": "PaltoCraft",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "assets/**",
      "node_modules/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PaltoCraft",
      "artifactName": "PaltoCraft-Setup-${version}.exe"
    }
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.16.2",
    "msmc": "^4.1.0",
    "skinview3d": "^3.4.1"
  },
  "overrides": {
    "request": "file:./request-shim",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "javascript-obfuscator": "^5.4.1"
  },
  "author": "PaltoCraft",
  "license": "MIT"
}
